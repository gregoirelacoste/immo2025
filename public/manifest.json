{
  "name": "tiili — Simulateur d'investissement locatif",
  "short_name": "tiili",
  "description": "Calculez la rentabilité de vos investissements immobiliers",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#f4f3ef",
  "theme_color": "#d97706",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/api/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "url": "url",
      "text": "text",
      "title": "title",
      "files": [
        {
          "name": "images",
          "accept": ["image/png", "image/jpeg", "image/webp"]
        }
      ]
    }
  }
}
