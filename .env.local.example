# =============================================================================
# Immo2025 — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# =============================================================================

# --- Base de données (SQLite / Turso) ---
# En local : file:data.db (défaut, rien à configurer)
# En prod  : URL Turso + token
TURSO_DATABASE_URL=file:data.db
TURSO_AUTH_TOKEN=

# --- Authentification (NextAuth v5) ---
# Secret pour signer les sessions (générer avec : openssl rand -base64 32)
AUTH_SECRET=dev-secret-change-in-production

# --- Google OAuth (optionnel — login Google) ---
# Console : https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Mettre "true" pour afficher le bouton Google sur la page login
NEXT_PUBLIC_GOOGLE_AUTH=false

# --- Gemini AI (scraping intelligent + extraction texte) ---
# Obtenir une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- APIs open data (aucune clé nécessaire) ---
# Les données socio-économiques utilisent des APIs publiques :
# - INSEE Données Locales (api.insee.fr) — population, revenus, emploi
# - data.education.gouv.fr — écoles à proximité
# - georisques.gouv.fr — risques naturels
# - geo.api.gouv.fr — géocodage, population commune
# - DVF (data.gouv.fr) — prix immobiliers
# Aucune configuration requise.
